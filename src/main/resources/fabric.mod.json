	"name": "The Hivemind",
	"description": "Control autonomous drone entities through a neural HiveMind network.",
	"authors": ["Sanfonic1!"],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/Thenexus96/The-HiveMind-A-Minecraft-Mod"
	},
	"license": "MIT",
